{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    { "identifier": "fs:allow-read-text-file",  "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPDATA/**/*" }, { "path": "$APPDATA/**/.*" }] },
    { "identifier": "fs:allow-write-text-file", "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPDATA/**/*" }, { "path": "$APPDATA/**/.*" }] },
    { "identifier": "fs:allow-mkdir",           "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPDATA/**/*" }, { "path": "$APPDATA/**/.*" }] },
    { "identifier": "fs:allow-read-dir",        "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPDATA/**/*" }, { "path": "$APPDATA/**/.*" }] },
    { "identifier": "fs:allow-remove",          "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPDATA/**/*" }, { "path": "$APPDATA/**/.*" }] },
    { "identifier": "fs:allow-rename",          "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPDATA/**/*" }, { "path": "$APPDATA/**/.*" }] },
    { "identifier": "fs:allow-exists",          "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPDATA/**/*" }, { "path": "$APPDATA/**/.*" }] }
  ]
}
